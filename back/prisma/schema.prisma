// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Catalog {
  catalogId Int    @id @default(autoincrement())
  name      String
  type      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CatalogItem[]
}

model CatalogItem {
  catalogItemId Int     @id @default(autoincrement())
  name          String
  isActive      Boolean @default(true)

  catalogId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catalog Catalog @relation(fields: [catalogId], references: [catalogId])

  enrollmentsWithGrade      Enrollment[]       @relation("EnrollmentGrade")
  enrollmentsWithGroup      Enrollment[]       @relation("EnrollmentGroup")
  usersWithRole             User[]             @relation("UserRole")
  usersWithStatus           User[]             @relation("UserStatus")
  personalInfosWithGender   PersonalInfo[]     @relation("Gender")
  studentsWithStatus        Student[]          @relation("StudentStatus")
  studentDocumentsWithType  StudentDocument[]  @relation("StudentDocumentType")
  guardianDocumentsWithType GuardianDocument[] @relation("GuardianDocumentType")
}

model PersonalInfo {
  personalInfoId Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  birthDate      DateTime

  genderId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?

  gender CatalogItem @relation("Gender", fields: [genderId], references: [catalogItemId])
}

model ContactInfo {
  contactInfoId Int    @id @default(autoincrement())
  email         String
  phone         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

model ProfilePhoto {
  profilePhotoId Int    @id @default(autoincrement())
  publicId       String
  url            String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

model User {
  userId   Int    @id @default(autoincrement())
  username String @unique
  password String

  roleId   Int
  statusId Int

  personalInfoId Int  @unique
  contactInfoId  Int  @unique
  profilePhotoId Int? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student  Student?
  teacher  Teacher?
  guardian Guardian?

  role   CatalogItem @relation("UserRole", fields: [roleId], references: [catalogItemId])
  status CatalogItem @relation("UserStatus", fields: [statusId], references: [catalogItemId])

  personalInfo PersonalInfo  @relation(fields: [personalInfoId], references: [personalInfoId])
  contactInfo  ContactInfo   @relation(fields: [contactInfoId], references: [contactInfoId])
  profilePhoto ProfilePhoto? @relation(fields: [profilePhotoId], references: [profilePhotoId])
}

model Address {
  addressId Int @id @default(autoincrement())

  street       String
  neighborhood String
  city         String
  state        String
  zipCode      String
  reference    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardians Guardian[]
  students  Student[]
}

model Guardian {
  guardianId Int @id @default(autoincrement())

  userId    Int @unique
  addressId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students  Student[]
  documents GuardianDocument[]

  user    User    @relation(fields: [userId], references: [userId])
  address Address @relation(fields: [addressId], references: [addressId])
}

model Student {
  studentId Int @id @default(autoincrement())

  userId          Int @unique
  addressId       Int
  guardianId      Int
  studentStatusId Int

  enrollmentNumber String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents   StudentDocument[]
  enrollments Enrollment[]

  user     User     @relation(fields: [userId], references: [userId])
  address  Address  @relation(fields: [addressId], references: [addressId])
  guardian Guardian @relation(fields: [guardianId], references: [guardianId])

  status CatalogItem @relation("StudentStatus", fields: [studentStatusId], references: [catalogItemId])
}

model Teacher {
  teacherId Int @id @default(autoincrement())

  userId Int @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId])
}

model StudentDocument {
  studentDocumentId Int @id @default(autoincrement())

  studentId      Int
  documentTypeId Int

  publicId String
  url      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student     @relation(fields: [studentId], references: [studentId])
  type    CatalogItem @relation("StudentDocumentType", fields: [documentTypeId], references: [catalogItemId])
}

model GuardianDocument {
  guardianDocumentId Int @id @default(autoincrement())

  guardianId     Int
  documentTypeId Int

  publicId String
  url      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardian Guardian    @relation(fields: [guardianId], references: [guardianId])
  type     CatalogItem @relation("GuardianDocumentType", fields: [documentTypeId], references: [catalogItemId])
}

model SchoolCycle {
  schoolCycleId Int @id @default(autoincrement())

  name      String
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]
}

model Enrollment {
  enrollmentId Int @id @default(autoincrement())

  schoolCycleId Int
  studentId     Int
  gradeId       Int
  groupId       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     Student     @relation(fields: [studentId], references: [studentId])
  schoolCycle SchoolCycle @relation(fields: [schoolCycleId], references: [schoolCycleId])

  grade CatalogItem @relation("EnrollmentGrade", fields: [gradeId], references: [catalogItemId])
  group CatalogItem @relation("EnrollmentGroup", fields: [groupId], references: [catalogItemId])
}
